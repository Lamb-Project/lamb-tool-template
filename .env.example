# lamb-tool-template configuration
# Copy to .env and fill in. The app refuses to start with missing REQUIRED
# values — there are deliberately no working defaults.

# --- Admin console (REQUIRED) ----------------------------------------------
# Protects the /admin page, where you set the LAMB and LTI configuration.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# --- Deployment (REQUIRED) --------------------------------------------------
# Public URL of THIS tool as the LMS sees it. Required behind a reverse
# proxy: the OAuth signature is computed over the URL the LMS used, and the
# admin page shows "<PUBLIC_BASE_URL>/lti/launch" as the tool URL to register.
PUBLIC_BASE_URL=http://localhost:8080

# --- App (optional) ---------------------------------------------------------
TOOL_DB_PATH=data/tool.db
SESSION_HOURS=8
ADMIN_SESSION_HOURS=12

# --- Runtime config: normally set on the /admin page, NOT here --------------
# The LAMB connection and LTI credentials are configured through the admin
# console and stored in the database. The variables below are OPTIONAL: if
# set, they only PRE-SEED the settings on first boot (handy for Docker/CI).
# Once saved via /admin, the stored value wins and these are ignored.
# LAMB_API_BASE=http://localhost:9099
# LAMB_API_KEY=
# LTI_CONSUMER_KEY=
# LTI_SECRET=
