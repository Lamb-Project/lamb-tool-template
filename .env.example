# lamb-tool-template configuration
# Copy to .env and fill in. The app refuses to start with missing values —
# there are deliberately NO working defaults.

# --- LAMB connection -------------------------------------------------------
# Base URL of your LAMB instance (the OpenAI-compatible surface).
LAMB_API_BASE=http://localhost:9099
# API key used to call LAMB. Use your creator API key once your LAMB
# instance issues them; a shared bearer token also works where that is
# what your deployment provides.
LAMB_API_KEY=

# --- LTI 1.1 (must match the External Tool config in your LMS) -------------
LTI_CONSUMER_KEY=
LTI_SECRET=

# --- App --------------------------------------------------------------------
# Public base URL of THIS tool as the LMS sees it. Required behind a
# reverse proxy: the OAuth signature is computed over the URL the LMS
# used, not the URL uvicorn sees.
PUBLIC_BASE_URL=http://localhost:8080
# SQLite database location.
TOOL_DB_PATH=data/tool.db
# Session lifetime in hours.
SESSION_HOURS=8
